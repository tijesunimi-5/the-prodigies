generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Registration {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  phone        String
  eventName    String
  amountPaid   Int
  couponUsed   String?
  receiptUrl   String?  // Cloudinary URL for the OPay screenshot
  status       String   @default("pending") // pending, verified, declined
  accessCode   String?  @unique // Generated once verified (QR data)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Nominee {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  votes     Vote[]
}

model Vote {
  id         String   @id @default(cuid())
  voterEmail String   @unique // Prevents double voting
  nomineeId  String
  nominee    Nominee  @relation(fields: [nomineeId], references: [id])
}